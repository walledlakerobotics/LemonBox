[Unit]
Description=Chromium Kiosk
After=graphical.target

[Service]
User=definition
Environment=XAUTHORITY=/home/user/.Xauthority
Environment=DISPLAY=:0
ExecStart=/usr/bin/chromium-browser --noerrdialogs --disable-infobars --kiosk http://localhost:7070/ 
Restart=on-abort

[Install]
WantedBy=graphical.target